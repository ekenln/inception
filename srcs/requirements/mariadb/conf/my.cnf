[mysqld]
user = mysql
port = 3306
bind-address = 0.0.0.0 #allows connections from outside the container
skip-networking = 0 #allows connections with the port not only socket
datadir = /var/lib/mysql 
pid-file = /run/mysqld/mysqld.pid # process id of the 
socket = /run/mysqld/mysqld.sock #for local connections inside the container, bypass the TCP/IP
max_connections = 100

[client]
port = 3306
socket = /run/mysqld/mysqld.sock